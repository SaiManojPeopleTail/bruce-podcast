# Gemini API key (same one as in your Laravel .env)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: use a more powerful model for the agent loop (default: gemini-2.5-flash)
GEMINI_AGENT_MODEL=gemini-2.5-flash

# ── Social credentials (used when no DB credentialId is passed) ──────────────
# Instagram burner account — recommended to use a dedicated account, not personal
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

# LinkedIn (optional)
LINKEDIN_USERNAME=
LINKEDIN_PASSWORD=

# Port + bind address (keep 127.0.0.1 — only Laravel should reach this)
SCRAPER_PORT=7501
SCRAPER_BIND=127.0.0.1

# Shared secret passed in X-Scraper-Secret header by Laravel
# Generate with: openssl rand -hex 32
SCRAPER_INTERNAL_SECRET=

# Directory for storing Playwright storageState (cookie cache) files
STORAGE_DIR=./data

# Force headless on Linux (set automatically; override if needed)
# HEADLESS=true

# Max concurrent Chromium sessions (raise when using parallel workers)
MAX_CONCURRENT_SESSIONS=8

# Active scraping timeout in minutes (excludes Gemini retry sleep — default 20)
SCRAPER_TIMEOUT_MIN=30

# Max posts to collect per scrape run (default 8)
SCRAPER_MAX_POSTS=8

# Parallel workers: when max posts exceeds threshold, split across workers
SCRAPER_PARALLEL_THRESHOLD=3
SCRAPER_POSTS_PER_WORKER=2
